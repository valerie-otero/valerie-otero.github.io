            "value" : "Diff."
          }
        }
      }
    },
    "Écart invraisemblable (hors 0,7–1,3) : calibrage refusé." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Implausible deviation (outside 0.7–1.3): calibration rejected."
          }
        }
      }
    },
    "Efface tous vos récipients et liquides (y compris sur vos appareils synchronisés iCloud) et restaure les exemples de départ." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erases all your containers and liquids (including on your iCloud-synced devices) and restores the starting examples."
          }
        }
      }
    },
    "Exemple : 50 mm → 5 L, puis 150 mm → 18 L. Au moins 2 points ; touchez « + » pour en ajouter, balayez une ligne pour la supprimer." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Example: 50 mm → 5 L, then 150 mm → 18 L. At least 2 points; tap “+” to add one, swipe a row to delete it."
          }
        }
      }
    },
