    "Forme libre" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Free form"
          }
        }
      }
    },
    "Forme quelconque, sans dimensions : on la définit par des mesures hauteur → volume." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Any shape, no dimensions: defined by height → volume measurements."
          }
        }
      }
    },
    "Formes régulières = calculées d'après les cotes. Formes composées (puisard, fond incliné) = calculées aussi. Forme libre = définie par vos mesures." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regular shapes = computed from dimensions. Composite shapes (sump, sloped bottom) = computed too. Free form = defined by your measurements."
          }
        }
      }
    },
    "Fût ou bidon debout — diamètre × hauteur." : {
