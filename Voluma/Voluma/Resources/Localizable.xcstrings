    "Ajouter un point" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add a point"
          }
        }
      }
    },
    "Ajuste un facteur k (entre 0,7 et 1,3) pour qu'une hauteur mesurée corresponde à un volume connu — par exemple un ticket de plein." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjusts a factor k (between 0.7 and 1.3) so a measured height matches a known volume — for example a fill-up receipt."
          }
        }
      }
    },
