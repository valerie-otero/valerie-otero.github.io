    "·" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "·"
          }
        }
      }
    },
    "· calibré" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "· calibrated"
          }
        }
      }
    },
    "« H. exacte » : hauteur théorique pour graver la pige. « Repère » : hauteur arrondie au cm ; « Écart » : volume induit par l'arrondi. Outil d'aide à la lecture, sans valeur métrologique : une mesure imprécise fausse le résultat ; l'utilisateur est responsable de l'exactitude des mesures." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Exact h.”: theoretical height for engraving the dipstick. “Mark”: height rounded to the cm; “Diff.”: volume caused by the rounding. A reading aid, with no metrological value: an inaccurate measurement distorts the result; the user is responsible for the accuracy of the measurements."
          }
        }
      }
    },
    "« H. exacte » : hauteur théorique pour le volume indiqué. « Repère » : hauteur arrondie au cm pour une lecture à la pige ; « Écart » : volume induit par cet arrondi. Les repères majeurs sont en gras et en couleur." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Exact h.”: theoretical height for the indicated volume. “Mark”: height rounded to the cm for a dipstick reading; “Diff.”: volume caused by that rounding. Major marks are shown in bold and colour."
          }
        }
      }
    },
